{
  "role_permissions": {
    "super_admin": {
      "description": "Full system access",
      "permissions": [
        "all"
      ]
    },
    "admin": {
      "description": "Administrative access",
      "permissions": [
        "users:manage",
        "system:configure",
        "data:read",
        "data:write",
        "plugins:manage"
      ]
    },
    "user": {
      "description": "Standard user access",
      "permissions": [
        "chat:use",
        "data:read_own",
        "profile:manage_own"
      ]
    }
  }
}
