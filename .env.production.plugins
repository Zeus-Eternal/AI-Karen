# =============================================================================
# AI KAREN - PRODUCTION PLUGIN ECOSYSTEM CONFIGURATION
# =============================================================================
# This file contains production-specific settings for the plugin ecosystem
# Copy relevant sections to your production .env file
# Last updated: 2026-04-04

# -----------------------------------------------------------------------------
# PLUGIN ECOSYSTEM SETTINGS
# -----------------------------------------------------------------------------
# Production environment for plugin operations
PLUGIN_ENV=production

# Plugin storage locations
PLUGIN_STORAGE_DIR=/var/lib/karen/plugins
PLUGIN_CACHE_DIR=/var/cache/karen/plugins
PLUGIN_TEMP_DIR=/tmp/karen/plugins

# Plugin discovery settings
PLUGIN_DISCOVERY_ENABLED=true
PLUGIN_DISCOVERY_INTERVAL_MINUTES=60
PLUGIN_AUTO_UPDATE_ENABLED=true
PLUGIN_AUTO_UPDATE_CHECK_HOURS=24

# Plugin lifecycle settings
PLUGIN_INSTALLATION_TIMEOUT_SECONDS=300
PLUGIN_UNINSTALLATION_TIMEOUT_SECONDS=120
PLUGIN_VALIDATION_ENABLED=true
PLUGIN_VALIDATION_STRICT=true

# -----------------------------------------------------------------------------
# DATABASE SETTINGS (PostgreSQL - Production)
# -----------------------------------------------------------------------------
# Production database connection
DATABASE_URL=postgresql://karen_user:secure_password@localhost:5432/karen_production
DATABASE_SSL_MODE=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Plugin registry database
PLUGIN_REGISTRY_DATABASE_URL=postgresql://karen_user:secure_password@localhost:5432/karen_plugins
PLUGIN_REGISTRY_POOL_SIZE=15
PLUGIN_REGISTRY_MAX_OVERFLOW=20

# Connection settings
DATABASE_ECHO=false
DATABASE_AUTOCOMMIT=false
DATABASE_ISOLATION_LEVEL=READ COMMITTED

# -----------------------------------------------------------------------------
# CACHE SETTINGS (Redis - Production)
# -----------------------------------------------------------------------------
# Production Redis connection
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=secure_redis_password
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required

# Plugin cache settings
PLUGIN_CACHE_TTL_SECONDS=3600
PLUGIN_CACHE_MAX_SIZE_MB=1024
PLUGIN_CACHE_ENABLED=true
PLUGIN_CACHE_COMPRESSION=true

# UI materialization cache
UI_CACHE_TTL_SECONDS=1800
UI_CACHE_MAX_SIZE_MB=512
UI_CACHE_COMPRESSION=true

# -----------------------------------------------------------------------------
# SECURITY SETTINGS
# -----------------------------------------------------------------------------
# Plugin security
PLUGIN_SANDBOX_ENABLED=true
PLUGIN_SANDBOX_ISOLATION_LEVEL=strict
PLUGIN_RESOURCE_LIMITS_ENABLED=true
PLUGIN_PERMISSION_VALIDATION_STRICT=true

# Plugin execution limits
PLUGIN_MAX_MEMORY_MB=512
PLUGIN_MAX_CPU_PERCENT=20
PLUGIN_MAX_DISK_MB=1024
PLUGIN_MAX_NETWORK_CONNECTIONS=10
PLUGIN_EXECUTION_TIMEOUT_SECONDS=60

# Template security
TEMPLATE_SECURITY_ENABLED=true
TEMPLATE_STRICT_UNDEFINED=true
TEMPLATE_MAX_COMPLEXITY=1000
TEMPLATE_MAX_VARIABLES=100

# -----------------------------------------------------------------------------
# MARKETPLACE SETTINGS
# -----------------------------------------------------------------------------
# Production marketplace
MARKETPLACE_ENABLED=true
MARKETPLACE_URL=https://store.karen.ai
MARKETPLACE_API_VERSION=v1
MARKETPLACE_CACHE_ENABLED=true
MARKETPLACE_CACHE_TTL_SECONDS=1800

# Marketplace sources
MARKETPLACE_SOURCES_ENABLED=github,gitlab,npm,pypi,custom
MARKETPLACE_GITHUB_TOKEN=github_token_placeholder
MARKETPLACE_GITLAB_TOKEN=gitlab_token_placeholder

# Plugin installation
MARKETPLACE_AUTO_INSTALL_VERIFICATION=true
MARKETPLACE_SIGNATURE_VERIFICATION_ENABLED=true
MARKETPLACE_REPOSITORY_VALIDATION_ENABLED=true

# -----------------------------------------------------------------------------
# HEALTH MONITORING SETTINGS
# -----------------------------------------------------------------------------
# Health dashboard configuration
HEALTH_DASHBOARD_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_METRICS_RETENTION_DAYS=30
HEALTH_ALERTS_ENABLED=true

# Alert thresholds
HEALTH_ALERT_CRITICAL_THRESHOLD=90
HEALTH_ALERT_WARNING_THRESHOLD=70
HEALTH_ALERT_DEGRADATION_THRESHOLD=50

# Health data collection
HEALTH_COLLECT_CPU=true
HEALTH_COLLECT_MEMORY=true
HEALTH_COLLECT_DISK=true
HEALTH_COLLECT_NETWORK=true
HEALTH_COLLECT_PLUGIN_METRICS=true

# -----------------------------------------------------------------------------
# LOGGING SETTINGS
# -----------------------------------------------------------------------------
# Plugin logging
PLUGIN_LOG_LEVEL=INFO
PLUGIN_LOG_FILE=/var/log/karen/plugins.log
PLUGIN_LOG_MAX_SIZE_MB=100
PLUGIN_LOG_ROTATION_COUNT=5

# Error logging
PLUGIN_ERROR_LOG_ENABLED=true
PLUGIN_ERROR_LOG_FILE=/var/log/karen/plugins_error.log
PLUGIN_ERROR_LOG_MAX_SIZE_MB=50
PLUGIN_ERROR_LOG_ROTATION_COUNT=3

# Access logging
PLUGIN_ACCESS_LOG_ENABLED=true
PLUGIN_ACCESS_LOG_FILE=/var/log/karen/plugins_access.log
PLUGIN_ACCESS_LOG_MAX_SIZE_MB=100
PLUGIN_ACCESS_LOG_ROTATION_COUNT=5

# -----------------------------------------------------------------------------
# PERFORMANCE SETTINGS
# -----------------------------------------------------------------------------
# Plugin performance optimization
PLUGIN_PERFORMANCE_OPTIMIZATION_ENABLED=true
PLUGIN_ASYNC_LOADING_ENABLED=true
PLUGIN_PARALLEL_LOADING_ENABLED=true
PLUGIN_LOADING_MAX_CONCURRENT=10

# Caching optimization
PLUGIN_TEMPLATE_CACHING_ENABLED=true
PLUGIN_TEMPLATE_CACHE_TTL_SECONDS=3600
PLUGIN_MANIFEST_CACHING_ENABLED=true
PLUGIN_MANIFEST_CACHE_TTL_SECONDS=7200

# -----------------------------------------------------------------------------
# BACKUP & RECOVERY SETTINGS
# -----------------------------------------------------------------------------
# Plugin backup
PLUGIN_BACKUP_ENABLED=true
PLUGIN_BACKUP_SCHEDULE=DAILY
PLUGIN_BACKUP_RETENTION_DAYS=30
PLUGIN_BACKUP_DIR=/var/backups/karen/plugins

# Recovery settings
PLUGIN_RECOVERY_ENABLED=true
PLUGIN_RECOVERY_CHECK_INTERVAL_MINUTES=30
PLUGIN_RECOVERY_MAX_RETRY_ATTEMPTS=3
PLUGIN_RECOVERY_RETRY_DELAY_SECONDS=60

# -----------------------------------------------------------------------------
# RATE LIMITING SETTINGS
# -----------------------------------------------------------------------------
# API rate limiting
PLUGIN_API_RATE_LIMIT_ENABLED=true
PLUGIN_API_RATE_LIMIT_PER_MINUTE=100
PLUGIN_API_RATE_LIMIT_BURST=200

# Plugin operation rate limiting
PLUGIN_OPERATION_RATE_LIMIT_ENABLED=true
PLUGIN_OPERATION_RATE_LIMIT_PER_MINUTE=50
PLUGIN_OPERATION_RATE_LIMIT_BURST=100

# -----------------------------------------------------------------------------
# NOTIFICATION SETTINGS
# -----------------------------------------------------------------------------
# Plugin notifications
PLUGIN_NOTIFICATIONS_ENABLED=true
PLUGIN_NOTIFICATION_EMAIL=admin@karen.ai
PLUGIN_NOTIFICATION_WEBHOOK_URL=https://karen.ai/webhooks/plugin-updates

# Notification types
PLUGIN_NOTIFICATION_ON_INSTALL=true
PLUGIN_NOTIFICATION_ON_UNINSTALL=true
PLUGIN_NOTIFICATION_ON_ERROR=true
PLUGIN_NOTIFICATION_ON_UPDATE=true
PLUGIN_NOTIFICATION_ON_SECURITY_ALERT=true

# -----------------------------------------------------------------------------
# CI/CD SETTINGS
# -----------------------------------------------------------------------------
# Deployment settings
DEPLOYMENT_MODE=production
DEPLOYMENT_STRATEGY=blue-green
DEPLOYMENT_ROLLBACK_ENABLED=true
DEPLOYMENT_HEALTH_CHECK_ENABLED=true
DEPLOYMENT_HEALTH_CHECK_TIMEOUT_SECONDS=300

# Build settings
BUILD_OPTIMIZATION=production
BUILD_MINIFY=true
BUILD_SOURCEMAPS=false
BUILD_TARGET=production

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Metrics collection
METRICS_ENABLED=true
METRICS_EXPORT_INTERVAL_SECONDS=60
METRICS_PROMETHEUS_ENABLED=true
METRICS_PROMETHEUS_PORT=9090
METRICS_PROMETHEUS_PATH=/metrics

# Distributed tracing
TRACING_ENABLED=true
TRACING_JAEGER_ENABLED=false
TRACING_OTEL_ENABLED=true
TRACING_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# CDN & ASSETS
# -----------------------------------------------------------------------------
# Static asset serving
CDN_ENABLED=false
CDN_URL=https://cdn.karen.ai
CDN_CACHE_TTL_SECONDS=86400

# Plugin assets
PLUGIN_ASSETS_CDN_ENABLED=false
PLUGIN_ASSETS_VERSIONING=true
PLUGIN_ASSETS_COMPRESSION=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Production feature flags
FEATURE_PLUGIN_MARKETPLACE_ENABLED=true
FEATURE_PLUGIN_HEALTH_DASHBOARD_ENABLED=true
FEATURE_PLUGIN_ANALYTICS_ENABLED=true
FEATURE_PLUGIN_AUTO_UPDATES_ENABLED=true
FEATURE_PLUGIN_SIGNED_INSTALLATIONS_ONLY=true

# Experimental features
FEATURE_EXPERIMENTAL_PLUGINS_ENABLED=false
FEATURE_BETA_PLUGINS_ENABLED=false
FEATURE_PLUGIN_TESTING_MODE_ENABLED=false