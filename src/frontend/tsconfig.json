{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": "..",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"],
    "typeRoots": [
      "../../ui_launchers/Karen-AI-Theme/node_modules/@types"
    ],
    "paths": {
      "@/*": ["../ui_launchers/Karen-AI-Theme/src/*"],
      "react": ["../../ui_launchers/Karen-AI-Theme/node_modules/react"],
      "react/jsx-runtime": ["../../ui_launchers/Karen-AI-Theme/node_modules/react/jsx-runtime"],
      "react-dom": ["../../ui_launchers/Karen-AI-Theme/node_modules/react-dom"],
      "lucide-react": ["../../ui_launchers/Karen-AI-Theme/node_modules/lucide-react"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.d.ts"],
  "exclude": ["node_modules"]
}
