{
  "name": "time-query",
  "display_name": "Date Time",
  "version": "0.1.0",
  "description": "Responds with the current time.",
  "purpose": "Provide the current date and time accurately based on the system clock.",
  "author": "Kari Team",
  "license": "MIT",
  "entrypoint": "handler:MainExtension",
  "category": "plugins",
  "tags": ["time", "date", "clock", "prompt-first"],
  "capabilities": {
    "provides_ui": true,
    "provides_api": true,
    "prompt_first": true
  },
  "ui": {
    "hook_zones": [
      {
        "zone": "sidebar.plugins",
        "label": "Date Time",
        "icon": "clock",
        "order": 0
      }
    ]
  },
  "rbac": {
    "allowed_roles": ["user", "admin", "developer"],
    "default_enabled": true
  }
}
