{
  "id": "time-query",
  "name": "time-query",
  "plugin_id": "time-query",
  "gui_manifest_version": "1.0",
  "display_name": "Time Query",
  "version": "0.2.0",
  "description": "App-wide time authority: current time, world clocks, stopwatches, alarms, and timezone conversions.",
  "category": "plugins",
  "intent": "time_query",
  "capabilities": {
    "provides_ui": true,
    "provides_api": true,
    "prompt_first": true
  },
  "ui": {
    "hook_zones": [
      {
        "zone": "sidebar.plugins",
        "label": "Time Query",
        "icon": "clock",
        "order": 0
      }
    ]
  },
  "rbac": {
    "allowed_roles": ["user", "admin", "developer"],
    "default_enabled": true
  },
  "entry": {
    "id": "time-query-main",
    "default": true,
    "entry_file": "TimeQueryPage.tsx"
  },
  "tags": ["time", "date", "clock", "stopwatch", "alarm", "timezone", "prompt-first"],
  "purpose": "Serve as the central source for all app time needs, including current time, world clocks, stopwatches, scheduled alarms, and timezone arithmetic."
}
