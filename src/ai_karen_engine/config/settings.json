{
  "expression": {
    "active_engine": "builtin",
    "engines": {
      "builtin": {
        "enabled": true,
        "type": "builtin_provider_engine",
        "fallback_eligible": false,
        "metadata": {
          "preferred_provider": "vllm",
          "preferred_model": "auto",
          "providers": {
            "vllm": {
              "enabled": true,
              "provider_type": "builtin",
              "base_url": "http://vllm:8000/v1",
              "health_url": "http://vllm:8000/health"
            },
            "transformers": {
              "enabled": true,
              "provider_type": "builtin",
              "model_path": "/app/models/transformers"
            }
          }
        }
      },
      "openai_compatible_local": {
        "enabled": false,
        "type": "openai_compatible",
        "fallback_eligible": false,
        "base_url": null
      },
      "llama_cpp_server": {
        "enabled": false,
        "type": "openai_compatible",
        "fallback_eligible": false,
        "base_url": null,
        "note": "Third-party endpoint: Configure llama.cpp server as OpenAI-compatible endpoint"
      },
      "glm": {
        "enabled": false,
        "type": "openai_compatible",
        "fallback_eligible": true,
        "base_url": "https://api.z.ai/api/coding/paas/v4",
        "note": "External provider: Requires Z.ai API key and admin approval"
      },
      "openai": {
        "enabled": false,
        "type": "openai_compatible",
        "fallback_eligible": true,
        "base_url": "https://api.openai.com/v1",
        "note": "External provider: Requires OpenAI API key"
      },
      "gemini": {
        "enabled": false,
        "type": "gemini",
        "fallback_eligible": true,
        "base_url": "https://generativelanguage.googleapis.com/v1beta",
        "note": "External provider: Requires Google AI API key"
      }
    },
    "policies": {
      "allow_third_party_engines": true,
      "allow_external_engines": false,
      "require_admin_for_external": true,
      "default_timeout_ms": 30000
    },
    "local_first_mode": true
  },
  "last_selected_model": "qwen3:4b",
  "use_memory": true,
  "context_length": 512,
  "decay": 0.1,
  "features": {
    "copilot_cloud_enabled": false,
    "copilot_advanced_ui": true,
    "copilot_batch_operations": true
  },
  "copilot": {
    "default_profile": "local_default",
    "max_concurrent_operations": 3,
    "timeout_seconds": 30,
    "enable_audit_logging": true
  },
  "chat": {
    "response_mode": "streaming_first",
    "streaming_enabled": true,
    "streaming_transport": "sse",
    "non_streaming_enabled": true,
    "streaming_status_events": true,
    "streaming_final_metadata": true
  },
  "plugins": {
    "enabled": [
      "model_orchestrator",
      "intelligent-search"
    ],
    "model_orchestrator": {
      "models_root": "./models",
      "registry_path": "./models/llm_registry.json",
      "max_concurrent_downloads": 3,
      "enable_metrics": true,
      "enable_rbac": true,
      "offline_mode": false,
      "mirror_url": null,
      "max_storage_gb": null,
      "enable_license_tracking": true,
      "enable_garbage_collection": true,
      "enable_compatibility_checks": true,
      "health_check_interval": 60,
      "auto_cleanup_enabled": true,
      "backup_registry": true
    },
    "intelligent-search": {
      "default_mode": "general",
      "default_provider": "duckduckgo",
      "max_urls": 5,
      "search": {
        "duckduckgo": {
          "enabled": true,
          "priority": 100
        },
        "tavily": {
          "enabled": false,
          "api_key": null,
          "priority": 90
        },
        "google_custom_search": {
          "enabled": false,
          "api_key": null,
          "cx_id": null,
          "priority": 80
        }
      },
      "general": {
        "max_urls": 5,
        "depth": 1,
        "freshness_bias": 0.3,
        "prefer_recent": false,
        "prefer_official_sources": false,
        "allow_forum_results": true
      }
    }
  },
  "provider": "ollama",
  "model": "qwen3:4b",
  "model_providers": {
    "builtin_transformers": {
      "last_model": "gpt2"
    },
    "builtin_vllm": {
      "last_model": "gpt2",
      "base_url": "http://vllm:8000/v1"
    },
    "gemini": {
      "last_model": "gemini-2.5-flash"
    },
    "ollama": {
      "last_model": "qwen3:4b",
      "base_url": "http://host.docker.internal:11434"
    }
  }
}