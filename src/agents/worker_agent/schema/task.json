{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Worker Agent Task",
  "description": "Schema for tasks processed by the worker agent",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "Type of task to be executed"
    },
    "data": {
      "type": "object",
      "description": "Data associated with the task"
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Priority level of the task (1-10)"
    },
    "deadline": {
      "type": "string",
      "format": "date-time",
      "description": "Deadline for task completion"
    }
  },
  "required": ["type", "data"]
}