{
  "id": "weather-query",
  "plugin_id": "weather-query",
  "category": "plugins",
  "gui_manifest_version": "1.0",
  "display_name": "Weather",
  "description": "Frontend GUI package for the Weather plugin in Karen-AI-Theme.",
  "entry": {
    "id": "weather-query-main",
    "default": true,
    "entry_file": "weather-query.tsx",
    "component_id": "weather-query"
  },
  "contributions": {
    "pages": [
      {
        "id": "weather-query-page",
        "label": "Weather",
        "entry_file": "weather-query.tsx",
        "route_key": "pluginWeatherQuery",
        "zone": "page.plugins.overview",
        "order": 0
      }
    ],
    "menu": [
      {
        "id": "weather-query-sidebar",
        "placement": "sidebar.plugins",
        "label": "Weather",
        "icon": "assets/weather-query---sidebar--main_00.svg",
        "order": 0
      }
    ],
    "settings_sections": [
      {
        "id": "weather-query-settings",
        "label": "Weather",
        "entry_file": "weather-query.tsx",
        "zone": "page.settings.sections",
        "order": 0
      }
    ],
    "dashboard_widgets": [
      {
        "id": "weather-query-widget",
        "label": "Weather",
        "entry_file": "components/WeatherWidget.tsx",
        "zone": "dashboard.widgets",
        "order": 0
      }
    ]
  },
  "assets": {
    "icons": [
      "assets/weather-query---sidebar--main_00.svg"
    ]
  },

  "rbac": {
    "allowed_roles": [
      "user",
      "admin",
      "developer"
    ]
  },
  "install": {
    "frontend_installable": true,
    "copy_source_root": "weather-query",
    "copy_required": true,
    "install_root": "ui_launchers/Karen-AI-Theme/src/plugin_repo/weather-query"
  },
  "validation": {
    "requires_entry_file": true,
    "requires_manifest": true,
    "requires_valid_contribution_zones": true,
    "default_entry_fallback": "weather-query.tsx"
  }
}