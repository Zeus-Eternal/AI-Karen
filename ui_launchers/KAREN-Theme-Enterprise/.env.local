# Development Environment Configuration
# This file contains development-specific settings for AI Karen Web UI

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Backend Configuration - Fixed for proper connectivity
KAREN_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_KAREN_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security Settings
NEXT_PUBLIC_ENABLE_DEVELOPMENT_FEATURES=true
NEXT_PUBLIC_ENABLE_DEVELOPER_TOOLS=true

# Logging and Debugging
KAREN_DEBUG_LOGGING=true
KAREN_ENABLE_REQUEST_LOGGING=true
KAREN_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_DEBUG_LOGGING=true

# Feature Flags
KAREN_ENABLE_EXPERIMENTAL_FEATURES=true
KAREN_ENABLE_EXTENSIONS=true
KAREN_ENABLE_MEMORY=true

# CORS Origins for development
KARI_CORS_ORIGINS=http://localhost:8010,http://127.0.0.1:8010,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000