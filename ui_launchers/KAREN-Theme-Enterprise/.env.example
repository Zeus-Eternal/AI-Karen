# =============================================================================
# AI KAREN - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and update with your specific values
# Last updated: 2025-12-12

# -----------------------------------------------------------------------------
# CORE ENVIRONMENT SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
ENVIRONMENT=development
SYSTEM_NAME=AI Karen Admin System

# -----------------------------------------------------------------------------
# BACKEND CONNECTIVITY
# -----------------------------------------------------------------------------
# Primary backend URLs
KAREN_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_KAREN_BACKEND_URL=http://localhost:8000
KAREN_BACKEND_PORT=8000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Fallback backend URLs (comma-separated)
KAREN_FALLBACK_BACKEND_URLS=http://127.0.0.1:8000,http://host.docker.internal:8000

# Health check interval
HEALTH_CHECK_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# JWT secrets (CHANGE IN PRODUCTION)
SECRET_KEY=change-me-in-production-secure-key
AUTH_SECRET_KEY=change-me-in-production-secure-key

# Development auth settings
AUTH_DEV_MODE=false
AUTH_ALLOW_DEV_LOGIN=false
AUTH_MODE=hybrid
SIMPLE_AUTH_ENABLED=true

# Session/Cookie settings
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_COOKIE_HTTPONLY=true
AUTH_SESSION_COOKIE_SAMESITE=lax
AUTH_SESSION_TIMEOUT_HOURS=24

# Security features (development)
AUTH_ENABLE_SECURITY_FEATURES=false
AUTH_ENABLE_RATE_LIMITING=false
AUTH_ENABLE_SESSION_VALIDATION=false
AUTH_ENABLE_INTELLIGENT_AUTH=false

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection settings
POSTGRES_USER=karen_user
POSTGRES_PASSWORD=karen_secure_pass_change_me
POSTGRES_DB=ai_karen
POSTGRES_PORT=5432

# Connection URLs
AUTH_DATABASE_URL=postgresql+asyncpg://karen_user:karen_secure_pass_change_me@localhost:5432/ai_karen
DATABASE_URL=postgresql://karen_user:karen_secure_pass_change_me@localhost:5432/ai_karen
POSTGRES_URL=postgresql+asyncpg://karen_user:karen_secure_pass_change_me@localhost:5432/ai_karen

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false

# Database health monitoring
DB_HEALTH_CHECK_INTERVAL=30
DB_MAX_CONNECTION_FAILURES=5
DB_CONNECTION_RETRY_DELAY=5

# Enhanced database settings
DB_CONNECTION_TIMEOUT=45
DB_QUERY_TIMEOUT=30
AUTH_DB_POOL_SIZE=10
AUTH_DB_POOL_MAX_OVERFLOW=20
AUTH_DB_CONNECTION_TIMEOUT=30
AUTH_DB_QUERY_TIMEOUT=30
AUTH_DB_ENABLE_QUERY_LOGGING=false

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secure_pass_change_me
REDIS_PORT=6380
REDIS_URL=redis://:redis_secure_pass_change_me@localhost:6380/0
REDIS_HOST=localhost
REDIS_DB=0

# -----------------------------------------------------------------------------
# OBJECT STORAGE (MinIO for Milvus)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=ai-karen-minio
MINIO_SECRET_KEY=ai-karen-minio-secret
MINIO_ROOT_USER=ai-karen-minio
MINIO_ROOT_PASSWORD=ai-karen-minio-secret
MINIO_PORT=9001

# -----------------------------------------------------------------------------
# VECTOR DATABASE (Milvus)
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19531
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=19531
MILVUS_HEALTH_WAIT_SECONDS=180
MILVUS_HEALTH_HOST=localhost
MILVUS_HEALTH_PORT=9091
MILVUS_HEALTH_PATH=/healthz

# -----------------------------------------------------------------------------
# ELASTICSEARCH CONFIGURATION
# -----------------------------------------------------------------------------
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# -----------------------------------------------------------------------------
# PERFORMANCE & RESOURCE OPTIMIZATION
# -----------------------------------------------------------------------------
# Resource Manager Settings (CPU optimized)
KAREN_MAX_MEMORY_MB=4096
KAREN_MAX_CPU_PERCENT=80.0
KAREN_RESOURCE_CHECK_INTERVAL=15.0

# CPU optimization settings
KARI_ENABLE_CPU_OPTIMIZATION=true
KARI_CPU_CORES=4
KARI_ENABLE_PARALLEL_PROCESSING=true
KARI_ENABLE_MEMORY_OPTIMIZATION=true
KARI_ENABLE_BATCH_PROCESSING=true
KARI_ENABLE_MODEL_QUANTIZATION=true
KARI_ENABLE_CPU_VECTORIZATION=true

# Threading optimization
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
OPENBLAS_NUM_THREADS=4
NUMEXPR_NUM_THREADS=4

# GPU settings (disabled - no GPU available)
CUDA_VISIBLE_DEVICES=""
PYTORCH_CUDA_ALLOC_CONF=""
DISTILBERT_ENABLE_GPU=false

# Memory optimization
ENABLE_MIXED_PRECISION=false
USE_FP16=false
USE_BF16=false

# -----------------------------------------------------------------------------
# LAZY LOADING & STARTUP OPTIMIZATION
# -----------------------------------------------------------------------------
KARI_LAZY_LOADING=true
KARI_MINIMAL_STARTUP=true
KARI_ULTRA_MINIMAL=true
KARI_DEFER_HEAVY_SERVICES=true
KARI_ESSENTIAL_ONLY=true
KARI_MAX_STARTUP_TIME=5.0
KARI_RESOURCE_MONITORING=true

# Service timeouts
KAREN_NLP_IDLE_TIMEOUT=120.0
KAREN_ORCHESTRATOR_IDLE_TIMEOUT=60.0
KAREN_ANALYTICS_IDLE_TIMEOUT=30.0
KARI_SERVICE_IDLE_TIMEOUT=180.0
KARI_CLEANUP_INTERVAL=60

# Performance optimization
ENABLE_PERFORMANCE_OPTIMIZATION=true
KARI_FAST_STARTUP=true
FAST_STARTUP=true

# Router optimization
KARI_DEFER_ROUTER_WIRING=false

# Model loading optimization
MAX_CONCURRENT_MODELS=1
MODEL_CACHE_SIZE=1
ENABLE_MODEL_UNLOADING=true
MODEL_IDLE_TIMEOUT=30
KARI_LAZY_MODEL_LOADING=true
KARI_MODEL_CACHE_SIZE=128

# -----------------------------------------------------------------------------
# MEMORY MANAGEMENT
# -----------------------------------------------------------------------------
# Memory service configuration
KARI_ENABLE_MEMORY_SERVICE=true
KARI_ENABLE_UNIFIED_MEMORY=true
KARI_MEMORY_SERVICE_TIMEOUT=30
KARI_MEMORY_SERVICE_MAX_RETRIES=3
KARI_MEMORY_FALLBACK_ENABLED=true

# Memory service offline mode
KARI_DISABLE_MEMORY_SURPRISE_FILTER=true
KARI_MEMORY_CACHE_TTL=300
KARI_MEMORY_FALLBACK_SCAN_LIMIT=500
KARI_MEMORY_RECENCY_ALPHA=0.05

# DistilBERT fallback settings
KARI_DISTILBERT_ENABLE_FALLBACK=true
KARI_DISTILBERT_CACHE_SIZE=1000
KARI_DISTILBERT_CACHE_TTL=3600

# Memory management
PYTHON_GC_THRESHOLD=100
ENABLE_MEMORY_PROFILING=true
FORCE_GC_INTERVAL=30

# -----------------------------------------------------------------------------
# MODEL & AI PROVIDER CONFIGURATION
# -----------------------------------------------------------------------------
# Model directories
LLAMA_CPP_MODELS_DIR=./models/gguf
TRANSFORMERS_MODELS_DIR=./models/transformers
MODELS_ROOT=./models
PLUGIN_DIR=/app/plugin_marketplace
CONFIG_PATH=/app/config

# spaCy pipelines
SPACY_PIPELINES=en_core_web_sm

# Cloud API keys (optional - add your keys here)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=

# Transformers configuration - disabled for now to ensure models load properly
TRANSFORMERS_OFFLINE=0
TRANSFORMERS_CACHE_DIR=/app/cache/transformers
HF_HUB_OFFLINE=0
HF_DATASETS_OFFLINE=0
TOKENIZERS_PARALLELISM=false

# Disable Hugging Face downloads completely
HF_HUB_DISABLE_TELEMETRY=1
DISABLE_HUGGINGFACE_HUB=1

# NLP settings
KARI_ENABLE_DEGRADED_HELPERS=1
SPACY_DOWNLOAD_MISSING=false

# -----------------------------------------------------------------------------
# MODEL ORCHESTRATOR CONFIGURATION
# -----------------------------------------------------------------------------
MODEL_ORCHESTRATOR_ENABLED=true
MODEL_ORCHESTRATOR_MAX_STORAGE_GB=100
MODEL_ORCHESTRATOR_ENABLE_METRICS=true
MODEL_ORCHESTRATOR_ENABLE_RBAC=true
MODEL_ORCHESTRATOR_HEALTH_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# EMAIL SERVICE CONFIGURATION
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_ENABLED=true
EMAIL_TEST_MODE=true

# SMTP settings
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Email sender
EMAIL_FROM=noreply@ai-karen.com
EMAIL_FROM_NAME=AI Karen Admin System
EMAIL_REPLY_TO=

# Email queue
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=5
EMAIL_BATCH_SIZE=10
EMAIL_RATE_LIMIT=60
EMAIL_PRIORITY_PROCESSING=true

# -----------------------------------------------------------------------------
# TIMEOUT & RETRY CONFIGURATION
# -----------------------------------------------------------------------------
# Timeouts (in milliseconds)
AUTH_TIMEOUT_MS=45000
CONNECTION_TIMEOUT_MS=30000
SESSION_VALIDATION_TIMEOUT_MS=30000
HEALTH_CHECK_TIMEOUT_MS=10000
DATABASE_TIMEOUT_MS=30000

# Retry configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=10000
RETRY_EXPONENTIAL_BASE=2
ENABLE_EXPONENTIAL_BACKOFF=true

# -----------------------------------------------------------------------------
# HTTP & PERFORMANCE CONFIGURATION
# -----------------------------------------------------------------------------
# HTTP Connection Pool
HTTP_CONNECTION_POOL_MAX_CONNECTIONS=50
HTTP_CONNECTION_POOL_MAX_PER_HOST=10
HTTP_CONNECTION_POOL_KEEP_ALIVE_TIMEOUT=60000
HTTP_CONNECTION_POOL_MAX_IDLE_TIME=300000
HTTP_CONNECTION_POOL_ENABLE_KEEP_ALIVE=true

# Request/Response Cache
RESPONSE_CACHE_MAX_SIZE=1000
RESPONSE_CACHE_DEFAULT_TTL=300000
RESPONSE_CACHE_MAX_MEMORY_USAGE=52428800
RESPONSE_CACHE_ENABLE_COMPRESSION=true
RESPONSE_CACHE_ENABLE_PERSISTENCE=false

# Database query optimization
DB_QUERY_CACHE_ENABLE=true
DB_QUERY_CACHE_TTL=300000
DB_QUERY_CACHE_MAX_SIZE=1000
DB_PREPARED_STATEMENTS_ENABLE=true
DB_SLOW_QUERY_THRESHOLD=1000

# Performance monitoring
PERFORMANCE_METRICS_ENABLE=true
PERFORMANCE_METRICS_INTERVAL=60000
PERFORMANCE_AUTO_OPTIMIZE=true

# -----------------------------------------------------------------------------
# EXTENSION & PLUGIN CONFIGURATION
# -----------------------------------------------------------------------------
# Extension Authentication
EXTENSION_API_KEY=dev-extension-api-key-change-in-production
EXTENSION_SECRET_KEY=dev-extension-secret-key-change-in-production

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:8010,http://127.0.0.1:8010,http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# GRAFANA CONFIGURATION
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# NEXT.JS CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_DISABLE_MINIFICATION=true
NEXT_PUBLIC_USE_PROXY=true
NEXT_PUBLIC_API_PROXY_TIMEOUT_MS=60000
NEXT_PUBLIC_API_PROXY_LONG_TIMEOUT_MS=180000
NEXT_PUBLIC_CHAT_PROXY_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Database services
KARI_ENABLE_VECTOR_DB=true
KARI_ENABLE_ELASTICSEARCH=true
KARI_ENABLE_DUCKDB=true

# Health and security
KAREN_ENABLE_HEALTH_CHECKS=true
ENABLE_SECURITY_ANALYSIS=true
KARI_SKIP_STARTUP_CHECK=false
KARI_SKIP_AUTO_INIT=false
ALLOW_PUBLIC_COPILOT=true

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------
# Debug settings
DEBUG=true
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_DEBUG_AUTH=true
DEBUG_AUTH=true

# Disable telemetry
KARI_DISABLE_ANALYTICS=false
KARI_DISABLE_TELEMETRY=false
KARI_ENABLE_GRACEFUL_DEGRADATION=true

# Logging
KARI_LOG_LEVEL=INFO
KARI_REDUCE_LOGGING=false

# -----------------------------------------------------------------------------
# GRACEFUL SHUTDOWN
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30
ENABLE_GRACEFUL_SHUTDOWN=true
