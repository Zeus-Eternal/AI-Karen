# =============================================================================
# AI KAREN - FRONTEND LOCAL ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND CONNECTIVITY
# -----------------------------------------------------------------------------
# Primary backend URL (points to the Python backend server)
NEXT_PUBLIC_KAREN_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_ENABLE_DEVELOPMENT_FEATURES=true

# -----------------------------------------------------------------------------
# TIMEOUT & RETRY CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CHAT_TIMEOUT_MS=25000
NEXT_PUBLIC_CHAT_RETRIES=2
NEXT_PUBLIC_CHAT_RETRY_BASE_MS=350
NEXT_PUBLIC_CHAT_RETRY_MAX_MS=3500
NEXT_PUBLIC_CHAT_MAX_MESSAGE_LENGTH=4000

# -----------------------------------------------------------------------------
# API TIMEOUTS (server-side)
# -----------------------------------------------------------------------------
KAREN_API_TIMEOUT_MS=30000
KAREN_API_RETRIES=2
KAREN_API_RETRY_BASE_MS=400
KAREN_API_RETRY_MAX_MS=4000

# -----------------------------------------------------------------------------
# OPTIONAL: FALLBACK BACKEND URLS
# -----------------------------------------------------------------------------
# KAREN_FALLBACK_BACKEND_URLS=http://127.0.0.1:8000,http://host.docker.internal:8000
