# =============================================================================
# AI KAREN - PLUGIN ECOSYSTEM DOCKERFILE
# =============================================================================
# Production Docker image for the plugin ecosystem
# Last updated: 2026-04-04

# Stage 1: Base Image
FROM python:3.13-slim as base

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=0 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    git \
    curl \
    libpq-dev \
    libxml2-dev \
    libxslt1-dev \
    zlib1g-dev \
    libjpeg-dev \
    libpng-dev \
    libffi-dev \
    libssl-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Stage 2: Build Dependencies
FROM base as builder

# Set working directory
WORKDIR /build

# Copy requirements files
COPY requirements.txt requirements-database.txt /build/

# Install Python dependencies
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r /build/requirements.txt && \
    pip install --no-cache-dir -r /build/requirements-database.txt && \
    rm -rf /root/.cache/pip

# Stage 3: Production Image
FROM python:3.13-slim as production

# Create non-root user for security
RUN groupadd -r karen && useradd -r -g karen karen

# Set working directory
WORKDIR /app

# Copy necessary files from builder stage
COPY --from=builder /usr/local/lib/python3.13/site-packages /usr/local/lib/python3.13/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY src/ /app/src/
COPY .env.production.plugins /app/.env.production

# Create necessary directories
RUN mkdir -p /var/lib/karen/plugins \
    /var/cache/karen/plugins \
    /tmp/karen/plugins \
    /var/log/karen \
    /var/backups/karen/plugins \
    /app/static/plugins

# Set ownership of directories
RUN chown -R karen:karen /app /var/lib/karen /var/cache/karen /tmp/karen /var/log/karen /var/backups/karen /app/static

# Install production dependencies only
RUN pip install --no-cache-dir gunicorn uvicorn[standard] psycopg2-binary redis

# Security hardening
RUN chmod 755 /app/src && \
    chmod 644 /app/.env.production && \
    chmod 750 /var/log/karen && \
    chmod 750 /var/lib/karen && \
    chmod 750 /var/cache/karen && \
    chmod 1777 /tmp/karen

# Switch to non-root user
USER karen

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/api/health/system || exit 1

# Expose ports
EXPOSE 8000

# Set default environment variables
ENV PORT=8000 \
    WORKERS=4 \
    WORKER_CLASS=uvicorn.workers.UvicornWorker \
    WORKER_CONNECTIONS=1000 \
    MAX_REQUESTS=10000 \
    TIMEOUT=120 \
    GRACEFUL_TIMEOUT=30 \
    KEEPALIVE=5 \
    LOG_LEVEL=info

# Default command
CMD ["gunicorn", \
    "--bind", "0.0.0.0:8000", \
    "--workers", "$WORKERS", \
    "--worker-class", "$WORKER_CLASS", \
    "--worker-connections", "$WORKER_CONNECTIONS", \
    "--max-requests", "$MAX_REQUESTS", \
    "--max-requests-jitter", "1000", \
    "--timeout", "$TIMEOUT", \
    "--graceful-timeout", "$GRACEFUL_TIMEOUT", \
    "--keepalive", "$KEEPALIVE", \
    "--log-level", "$LOG_LEVEL", \
    "--access-logfile", "-", \
    "--error-logfile", "-", \
    "--capture-output", \
    "src.ai_karen_engine.server:app"]

# Labels for metadata
LABEL maintainer="Karen AI Platform Team" \
      version="1.0.0" \
      description="Production plugin ecosystem image" \
      org.opencontainers.image.source=https://github.com/karen-ai/karen \
      org.opencontainers.image.licenses=MPL-2.0