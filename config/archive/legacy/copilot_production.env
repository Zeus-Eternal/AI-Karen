# CoPilot Production Environment Configuration
# This file contains environment variables for CoPilot production deployment

# General Settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
ACTIVE_USER=admin
THEME=light

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
SERVER_MAX_CONNECTIONS=1000
SERVER_KEEPALIVE_TIMEOUT=65
SERVER_GRACEFUL_TIMEOUT=30

# SSL Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/your-domain.crt
SSL_KEY_PATH=/etc/ssl/private/your-domain.key

# Database Configuration
POSTGRES_USER=karen_user
POSTGRES_DB=ai_karen_copilot
POSTGRES_PORT=5432
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=60
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_QUERY_TIMEOUT=20
DB_CONNECTION_TIMEOUT=30
DB_ENABLE_QUERY_LOGGING=true
DB_SLOW_QUERY_THRESHOLD_MS=500

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CONNECTION_POOL_SIZE=15
REDIS_DEFAULT_TTL=3600
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru
REDIS_COMPRESSION=true
REDIS_SERIALIZATION=json

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch-copilot
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=ai_karen_copilot

# Milvus Configuration
MILVUS_HOST=milvus-copilot
MILVUS_PORT=19530
MILVUS_HEALTH_WAIT_SECONDS=180
MILVUS_HEALTH_HOST=milvus-copilot
MILVUS_HEALTH_PORT=9091
MILVUS_HEALTH_PATH=/healthz
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# Memory Configuration
MEMORY_ENABLED=true
MEMORY_PROVIDER=milvus
MEMORY_EMBEDDING_DIM=768
MEMORY_DECAY_LAMBDA=0.1
MEMORY_QUERY_LIMIT=100
MEMORY_CACHE_SIZE=10000
MEMORY_BATCH_SIZE=1000
MEMORY_INDEX_TYPE=IVF_FLAT
MEMORY_METRIC_TYPE=L2

# Authentication Configuration
AUTH_MODE=hybrid
AUTH_SESSION_TIMEOUT_HOURS=8
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=30
AUTH_ENABLE_TWO_FACTOR_AUTH=true
AUTH_ENABLE_SESSION_VALIDATION=true
AUTH_RATE_LIMIT_STORAGE=redis
AUTH_RATE_LIMIT_REDIS_URL=redis://:${REDIS_PASSWORD}@redis-copilot:6379/0
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_MINUTES=1
AUTH_RATE_LIMIT_MAX_REQUESTS=60
AUTH_ALERT_COOLDOWN_MINUTES=30
AUTH_LOG_LEVEL=WARNING
AUTH_ALLOW_DEV_LOGIN=false

# Security Configuration
ENABLE_SECURITY_ANALYSIS=true
AUTH_ENABLE_RATE_LIMITING=true
KAREN_ENABLE_HEALTH_CHECKS=true
KARI_SKIP_STARTUP_CHECK=false
KARI_SKIP_AUTO_INIT=false
ALLOW_PUBLIC_COPILOT=false
ENABLE_SECURITY_HEADERS=true
CONTENT_SECURITY_POLICY_DEFAULT_SRC="'self'"
CONTENT_SECURITY_POLICY_SCRIPT_SRC="'self' 'unsafe-inline'"
CONTENT_SECURITY_POLICY_STYLE_SRC="'self' 'unsafe-inline'"
CONTENT_SECURITY_POLICY_IMG_SRC="'self' data: https:"
CONTENT_SECURITY_POLICY_CONNECT_SRC="'self' https://api.your-domain.com"
CONTENT_SECURITY_POLICY_FONT_SRC="'self'"
CONTENT_SECURITY_POLICY_OBJECT_SRC="'none'"
CONTENT_SECURITY_POLICY_MEDIA_SRC="'self'"
CONTENT_SECURITY_POLICY_FRAME_SRC="'none'"
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
FRAME_OPTIONS=DENY
CONTENT_TYPE_OPTIONS=nosniff
XSS_PROTECTION=1; mode=block
REFERRER_POLICY=strict-origin-when-cross-origin

# CoPilot Configuration
COPILOT_ENABLED=true
COPILOT_VERSION=1.0.0
COPILOT_HEALTH_CHECK_ENABLED=true
COPILOT_HEALTH_CHECK_INTERVAL=30
COPILOT_ENABLE_STREAMING=true
COPILOT_STREAMING_CHUNK_SIZE=1024
COPILOT_MAX_RESPONSE_SIZE_MB=10
COPILOT_ENABLE_INTERACTIVE_ELEMENTS=true
COPILOT_ENABLE_EXTENSIONS=true
COPILOT_ENABLE_MEMORY_INTEGRATION=true
COPILOT_ENABLE_RESPONSE_FORMATTING=true
COPILOT_ENABLE_THREAD_MANAGEMENT=true
COPILOT_ENABLE_SESSION_MANAGEMENT=true
COPILOT_ENABLE_REQUEST_VALIDATION=true
COPILOT_ENABLE_CONTENT_FILTERING=true
COPILOT_MAX_INPUT_LENGTH=10000
COPILOT_ENABLE_RATE_LIMITING=true
COPILOT_RATE_LIMIT_REQUESTS_PER_MINUTE=60
COPILOT_MAX_THREADS_PER_SESSION=10
COPILOT_THREAD_TIMEOUT_MINUTES=60
COPILOT_CLEANUP_INTERVAL_MINUTES=30
COPILOT_SESSION_TIMEOUT_MINUTES=120
COPILOT_MAX_SESSIONS_PER_USER=5
COPILOT_ENABLE_SESSION_PERSISTENCE=true
COPILOT_CONTEXT_WINDOW_SIZE=100
COPILOT_MAX_MEMORY_ENTRIES=1000
COPILOT_MEMORY_RETENTION_DAYS=30
COPILOT_MAX_CONCURRENT_EXTENSIONS=5
COPILOT_EXTENSION_TIMEOUT_SECONDS=60
COPILOT_ENABLE_LAZY_LOADING=true
COPILOT_ENABLE_RESPONSE_CACHING=true
COPILOT_CACHE_TTL_MINUTES=15
COPILOT_MAX_CONCURRENT_REQUESTS=100
COPILOT_REQUEST_TIMEOUT_SECONDS=30

# Model Orchestrator Configuration
MODEL_ORCHESTRATOR_ENABLED=true
MODEL_ORCHESTRATOR_MAX_STORAGE_GB=100
MODEL_ORCHESTRATOR_ENABLE_METRICS=true
MODEL_ORCHESTRATOR_ENABLE_RBAC=true
MODEL_ORCHESTRATOR_HEALTH_CHECK_INTERVAL=60
MODEL_ORCHESTRATOR_MODELS_ROOT=/app/models
MODEL_ORCHESTRATOR_REGISTRY_PATH=/app/models/llm_registry.json
MODEL_ORCHESTRATOR_MAX_CONCURRENT_DOWNLOADS=3
MODEL_ORCHESTRATOR_OFFLINE_MODE=false
MODEL_ORCHESTRATOR_MIRROR_URL=null
MODEL_ORCHESTRATOR_ENABLE_LICENSE_TRACKING=true
MODEL_ORCHESTRATOR_ENABLE_GARBAGE_COLLECTION=true
MODEL_ORCHESTRATOR_ENABLE_COMPATIBILITY_CHECKS=true
MODEL_ORCHESTRATOR_BACKUP_REGISTRY=true
MODEL_ORCHESTRATOR_AUTO_CLEANUP_ENABLED=true
MODEL_ORCHESTRATOR_GC_THRESHOLD_GB=80
MODEL_ORCHESTRATOR_PIN_ESSENTIAL_MODELS=true
MODEL_ORCHESTRATOR_RBAC_CONFIG_PATH=/app/config/model_orchestrator_rbac.yml
MODEL_ORCHESTRATOR_ENABLE_AUDIT_LOGGING=true
MODEL_ORCHESTRATOR_AUDIT_RETENTION_DAYS=365
MODEL_ORCHESTRATOR_MAX_FILE_SIZE_GB=10
MODEL_ORCHESTRATOR_ALLOWED_MODEL_OWNERS=[]
MODEL_ORCHESTRATOR_BLOCKED_MODEL_OWNERS=[]
MODEL_ORCHESTRATOR_REQUIRE_LICENSE_ACCEPTANCE=true
MODEL_ORCHESTRATOR_DOWNLOAD_TIMEOUT_MINUTES=30
MODEL_ORCHESTRATOR_RETRY_ATTEMPTS=3
MODEL_ORCHESTRATOR_RETRY_BACKOFF_SECONDS=5
MODEL_ORCHESTRATOR_CONCURRENT_HEALTH_CHECKS=5
MODEL_ORCHESTRATOR_CACHE_MODEL_INFO_MINUTES=15
MODEL_ORCHESTRATOR_ENABLE_PROMETHEUS_METRICS=true
MODEL_ORCHESTRATOR_ENABLE_OPENTELEMETRY_TRACING=true
MODEL_ORCHESTRATOR_LOG_LEVEL=INFO
MODEL_ORCHESTRATOR_METRICS_PORT=9090
MODEL_ORCHESTRATOR_HEALTH_ENDPOINT=/api/models/health

# LLM Configuration
LLM_MODEL=production-model
DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MPNet-base-v2
SPACY_MODEL=en_core_web_sm
TRANSFORMERS_OFFLINE=true
HF_HUB_OFFLINE=1
TOKENIZERS_PARALLELISM=false
SPACY_DOWNLOAD_MISSING=false
KARI_ENABLE_DEGRADED_HELPERS=0

# Monitoring Configuration
MONITORING_METRICS_ENABLED=true
MONITORING_METRICS_PORT=9090
MONITORING_METRICS_PATH=/metrics
MONITORING_METRICS_INCLUDE_DEFAULT_METRICS=true
MONITORING_METRICS_CUSTOM_METRICS=true
MONITORING_HEALTH_CHECKS_ENABLED=true
MONITORING_HEALTH_CHECKS_INTERVAL_SECONDS=30
MONITORING_HEALTH_CHECKS_TIMEOUT_SECONDS=5
MONITORING_HEALTH_CHECKS_ENDPOINTS=/api/health,/api/health/database,/api/health/cache,/api/health/memory
MONITORING_TRACING_ENABLED=true
MONITORING_TRACING_SAMPLE_RATE=0.1
MONITORING_TRACING_ENDPOINT=https://your-tracing-service.com/api/traces

# Rate Limiting Configuration
RATE_LIMITING_ENABLED=true
RATE_LIMITING_GLOBAL_WINDOW_MS=900000
RATE_LIMITING_GLOBAL_MAX_REQUESTS=1000
RATE_LIMITING_AUTH_LOGIN_WINDOW_MS=900000
RATE_LIMITING_AUTH_LOGIN_MAX_REQUESTS=10
RATE_LIMITING_CHAT_WINDOW_MS=60000
RATE_LIMITING_CHAT_MAX_REQUESTS=30
RATE_LIMITING_ADMIN_WINDOW_MS=60000
RATE_LIMITING_ADMIN_MAX_REQUESTS=100

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=https://your-domain.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Performance Configuration
PERFORMANCE_COMPRESSION_ENABLED=true
PERFORMANCE_COMPRESSION_LEVEL=6
PERFORMANCE_COMPRESSION_THRESHOLD=1024
PERFORMANCE_STATIC_FILES_CACHE_CONTROL=public, max-age=31536000
PERFORMANCE_STATIC_FILES_ETAG=true
PERFORMANCE_STATIC_FILES_LAST_MODIFIED=true
PERFORMANCE_REQUEST_TIMEOUT=30000
PERFORMANCE_KEEP_ALIVE_TIMEOUT=65000
PERFORMANCE_MAX_REQUEST_SIZE=50MB

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/var/backups/ai-karen-copilot
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_ALGORITHM=AES-256-GCM
BACKUP_COMPRESSION=true
BACKUP_VERIFY_INTEGRITY=true
BACKUP_INCLUDE_CONVERSATIONS=true
BACKUP_INCLUDE_SESSIONS=true
BACKUP_INCLUDE_USER_PREFERENCES=true
BACKUP_INCLUDE_EXTENSION_DATA=true
BACKUP_INCLUDE_MODELS=false
BACKUP_INCLUDE_REGISTRY=true
BACKUP_INCLUDE_CONFIG=true
BACKUP_INCLUDE_LOGS=true

# UI Configuration
UI_SHOW_DEBUG_INFO=false
UI_ENABLE_DEV_TOOLS=false
UI_THEME_SWITCHING=true
UI_DEFAULT_THEME=light
UI_BRANDING_COMPANY_NAME=Your Company
UI_BRANDING_LOGO_URL=/assets/logo.png
UI_BRANDING_FAVICON_URL=/assets/favicon.ico
UI_BRANDING_PRIMARY_COLOR=#007bff
UI_BRANDING_SECONDARY_COLOR=#6c757d
UI_FEATURES_ANALYTICS=true
UI_FEATURES_USER_FEEDBACK=true
UI_FEATURES_HELP_SYSTEM=true
UI_FEATURES_KEYBOARD_SHORTCUTS=true

# Integration Configuration
INTEGRATIONS_EMAIL_ENABLED=true
INTEGRATIONS_EMAIL_PROVIDER=smtp
INTEGRATIONS_EMAIL_TEMPLATES_PATH=/opt/ai-karen/templates/email
INTEGRATIONS_ANALYTICS_ENABLED=true
INTEGRATIONS_ANALYTICS_PROVIDER=google_analytics
INTEGRATIONS_ANALYTICS_TRACKING_ID=GA_TRACKING_ID
INTEGRATIONS_ERROR_TRACKING_ENABLED=true
INTEGRATIONS_ERROR_TRACKING_PROVIDER=sentry
INTEGRATIONS_ERROR_TRACKING_DSN=SENTRY_DSN

# Feature Flags
FEATURE_FLAGS_EXPERIMENTAL_FEATURES=false
FEATURE_FLAGS_BETA_FEATURES=false
FEATURE_FLAGS_ANALYTICS=true
FEATURE_FLAGS_TELEMETRY=false
FEATURE_FLAGS_ADVANCED_AUTH=true
FEATURE_FLAGS_MULTI_TENANT=false

# Resource Limits
RESOURCE_LIMITS_MAX_MEMORY_MB=4096
RESOURCE_LIMITS_MAX_CPU_PERCENT=80
RESOURCE_LIMITS_MAX_DISK_USAGE_PERCENT=85
RESOURCE_LIMITS_MAX_CONCURRENT_REQUESTS=100
RESOURCE_LIMITS_MAX_FILE_UPLOAD_MB=100

# Logging Configuration
LOGGING_LEVEL=INFO
LOGGING_FORMAT=json
LOGGING_STRUCTURED=true
LOGGING_CORRELATION_ID=true
LOGGING_FILE_LOGGING_ENABLED=true
LOGGING_FILE_LOGGING_PATH=/var/log/ai-karen-copilot/app.log
LOGGING_FILE_LOGGING_MAX_SIZE=100MB
LOGGING_FILE_LOGGING_BACKUP_COUNT=10
LOGGING_FILE_LOGGING_ROTATION=daily
LOGGING_CONSOLE_LOGGING_ENABLED=true
LOGGING_CONSOLE_LOGGING_COLORIZE=false
LOGGING_AUDIT_LOGGING_ENABLED=true
LOGGING_AUDIT_LOGGING_PATH=/var/log/ai-karen-copilot/audit.log
LOGGING_AUDIT_LOGGING_EVENTS=login,logout,admin_action,config_change,data_access
LOGGING_CONVERSATION_LOGGING_ENABLED=true
LOGGING_CONVERSATION_LOGGING_PATH=/var/log/ai-karen-copilot/conversations.log
LOGGING_INTERACTION_TRACKING_ENABLED=true
LOGGING_INTERACTION_LOGGING_PATH=/var/log/ai-karen-copilot/interactions.log
LOGGING_LOG_RETENTION_DAYS=30

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password
GRAFANA_PROVISIONING_PATH=/etc/grafana/provisioning

# Plugin Configuration
PLUGIN_DIR=/app/plugin_marketplace
PLUGINS_ENABLED=model_orchestrator,copilot_integration
PLUGINS_AUTO_LOAD=true
PLUGINS_MAX_CONCURRENT_EXTENSIONS=5
PLUGINS_EXTENSION_TIMEOUT_SECONDS=60

# CoPilot Integration Configuration
COPILOT_INTEGRATION_ENABLED=true
COPILOT_INTEGRATION_AGENT_SERVICE_ENDPOINT=/api/agent
COPILOT_INTEGRATION_CONVERSATION_SERVICE_ENDPOINT=/api/conversation
COPILOT_INTEGRATION_ENABLE_WEBSOCKET=true
COPILOT_INTEGRATION_WEBSOCKET_PATH=/ws/copilot
COPILOT_INTEGRATION_MAX_WEBSOCKET_CONNECTIONS=1000
COPILOT_INTEGRATION_WEBSOCKET_TIMEOUT_MINUTES=30
COPILOT_INTEGRATION_ENABLE_AUTHENTICATION=true
COPILOT_INTEGRATION_ENABLE_AUTHORIZATION=true
COPILOT_INTEGRATION_ENABLE_CORS=true
COPILOT_INTEGRATION_CORS_ORIGINS=https://your-domain.com
COPILOT_INTEGRATION_ENABLE_RESPONSE_COMPRESSION=true
COPILOT_INTEGRATION_COMPRESSION_LEVEL=6
COPILOT_INTEGRATION_ENABLE_REQUEST_CACHING=true
COPILOT_INTEGRATION_CACHE_TTL_SECONDS=300
COPILOT_INTEGRATION_ENABLE_METRICS=true
COPILOT_INTEGRATION_ENABLE_TRACING=true
COPILOT_INTEGRATION_METRICS_PORT=9094
COPILOT_INTEGRATION_HEALTH_ENDPOINT=/api/copilot-integration/health

# CoPilot UI Configuration
COPILOT_UI_THEME=light
COPILOT_UI_DEFAULT_LANGUAGE=en
COPILOT_UI_ENABLE_DARK_MODE=true
COPILOT_UI_ENABLE_ACCESSIBILITY_FEATURES=true
COPILOT_UI_ENABLE_DEV_TOOLS=false
COPILOT_UI_ENABLE_DEBUG_INFO=false
COPILOT_UI_ENABLE_THEME_SWITCHING=true
COPILOT_UI_ENABLE_USER_FEEDBACK=true
COPILOT_UI_ENABLE_HELP_SYSTEM=true
COPILOT_UI_ENABLE_KEYBOARD_SHORTCUTS=true
COPILOT_UI_ENABLE_ANALYTICS=true
COPILOT_UI_BRANDING_COMPANY_NAME=Your Company
COPILOT_UI_BRANDING_LOGO_URL=/assets/logo.png
COPILOT_UI_BRANDING_FAVICON_URL=/assets/favicon.ico
COPILOT_UI_BRANDING_PRIMARY_COLOR=#007bff
COPILOT_UI_BRANDING_SECONDARY_COLOR=#6c757d