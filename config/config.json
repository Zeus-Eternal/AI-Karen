  "services": {
    "ai_orchestrator": {},
    "memory_service": {},
    "conversation_service": {},
    "plugin_service": {},
    "tool_service": {},
    "analytics_service": {}
  },
  "security": {
    "jwt_secret": "dev-jwt-secret-change-in-production",
    "jwt_algorithm": "HS256",
    "jwt_expiration": 3600,
    "cors_origins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:8000",
      "http://127.0.0.1:8000",
      "http://localhost:8010",
      "http://127.0.0.1:8010",
      "http://localhost:8020",
      "http://127.0.0.1:8020"
