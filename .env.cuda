# CUDA Environment Variables Configuration
# Set these environment variables to enable CUDA support

# GPU Configuration
export CUDA_VISIBLE_DEVICES=0
export KARI_LOCAL_GGUF_HOST=local-gguf-cuda
export KARI_LOCAL_GGUF_PORT=8080
export KARI_LOCAL_GGUF_USE_CUDA=true

# Optional: Additional CUDA settings
export GGML_CUDA=1
export LLAMA_CUBLAS=1
export GGML_CUDA_DMM=1

# Docker settings
export DOCKER_DEFAULT_PLATFORM=linux/amd64

# Built-in vLLM OpenAI-compatible server
export KAREN_BUILTIN_VLLM_ENABLED=true
export KAREN_BUILTIN_VLLM_BASE_URL=http://vllm:8000/v1
export KAREN_BUILTIN_VLLM_HEALTH_URL=http://vllm:8000/health
export KAREN_BUILTIN_VLLM_HOST_PORT=8001
export KAREN_BUILTIN_VLLM_SERVED_MODEL_NAME=karen-vllm-local
export KAREN_BUILTIN_VLLM_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
export KAREN_BUILTIN_VLLM_DTYPE=auto
export KAREN_BUILTIN_VLLM_GPU_MEMORY_UTILIZATION=0.80
export KAREN_BUILTIN_VLLM_MAX_MODEL_LEN=4096
export KAREN_BUILTIN_VLLM_TIMEOUT_SECONDS=120
export KAREN_BUILTIN_VLLM_STREAMING_ENABLED=true
export KAREN_BUILTIN_VLLM_FALLBACK_ELIGIBLE=true

# Model configuration
export KARI_MODEL_PATH="./models/local-gguf/Phi-3-mini-4k-instruct-q4.gguf"
export KARI_N_GPU_LAYERS=-1
export KARI_N_CTX=4096
export KARI_N_BATCH=512
export KARI_MAIN_GPU=0
export KARI_OFFLOAD_KQV=true
export KARI_FLASH_ATTN=true
